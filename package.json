    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
